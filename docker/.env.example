# Hex4j 应用配置模板
# 复制此文件为 .env 并根据实际情况修改配置

APP_NAME=hex4j
APP_VERSION=0.0.1-SNAPSHOT

# Spring Boot 配置
SPRING_PROFILES_ACTIVE=dev
LOG_PATH=/app/logs

# PostgreSQL 配置
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hex
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123456  # 请修改为实际密码

# RabbitMQ 配置
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin123456  # 请修改为实际密码
RABBITMQ_MANAGEMENT_PORT=15672

# 应用容器配置
APP_PORT=8080
APP_JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# Jaeger 配置
JAEGER_UI_PORT=16686
JAEGER_COLLECTOR_PORT=14250

# Collector 配置
COLLECTOR_GRPC_PORT=4317
COLLECTOR_HTTP_PORT=4318

# Docker 镜像配置
POSTGRES_IMAGE=postgres:16.2-alpine
RABBITMQ_IMAGE=rabbitmq:3.13.1-management-alpine
